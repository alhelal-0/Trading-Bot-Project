//@version=6
strategy("Bollinger Band Mean Reversion 1:2 RR", overlay=true,
     initial_capital=100000,
     default_qty_type=strategy.fixed, default_qty_value=1,
     commission_type=strategy.commission.percent, commission_value=0.02)

// ------------------------------------------------------------
// Inputs
// ------------------------------------------------------------
bbLength   = input.int(20, "Bollinger period", minval=2)
bbMult     = input.float(2.0, "Std dev multiplier", minval=0.5, step=0.1)
nearPct    = input.float(10.0, "Near-band zone (% of band width)", minval=1, maxval=50) / 100.0
allowShort = input.bool(false, "Also take shorts near the upper band")
atrLen     = input.int(14, "ATR period")
stopAtr    = input.float(1.5, "Stop distance (ATRs)", minval=0.1, step=0.1)
rr         = input.float(2.0, "Reward : Risk", minval=0.5, step=0.5)

// ------------------------------------------------------------
// Bollinger Bands + ATR
// ------------------------------------------------------------
[bbMid, bbUpper, bbLower] = ta.bb(close, bbLength, bbMult)
bandWidth = bbUpper - bbLower
atrValue  = ta.atr(atrLen)

nearLower = close <= bbLower + bandWidth * nearPct
nearUpper = close >= bbUpper - bandWidth * nearPct

// ------------------------------------------------------------
// Entries with a fixed 1:2 bracket (stop 1R, target 2R)
// ------------------------------------------------------------
if nearLower and strategy.position_size == 0
    stopDist = stopAtr * atrValue
    strategy.entry("Long", strategy.long)
    strategy.exit("Long exit", "Long", stop=close - stopDist, limit=close + stopDist * rr)

if allowShort and nearUpper and strategy.position_size == 0
    stopDist = stopAtr * atrValue
    strategy.entry("Short", strategy.short)
    strategy.exit("Short exit", "Short", stop=close + stopDist, limit=close - stopDist * rr)

// ------------------------------------------------------------
// Visuals
// ------------------------------------------------------------
plot(bbMid, "Basis", color=color.orange)
pU = plot(bbUpper, "Upper band", color=color.red)
pL = plot(bbLower, "Lower band", color=color.blue)
fill(pU, pL, color=color.new(color.gray, 92))
bgcolor(nearLower ? color.new(color.blue, 85) : nearUpper ? color.new(color.red, 85) : na)
